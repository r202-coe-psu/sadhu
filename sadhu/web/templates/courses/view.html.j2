{% extends '/courses/index.html.j2' %}
{% import '/base/error-handler.html.j2' as eh %}

{% block dashboard_title %}
Courses: {{ course.name }}
{% endblock %}

{% block breadcrumbs %}
{{ super() }}
<li>{{ course.name }}</li>
{% endblock %}


{% block content %}
<div class="container mx-auto px-4">
  <div class="card bg-base-100 shadow">
		<div class="card-body">
		<h2 class="text-2xl font-bold">{{ course.name }}</h2>
		<div>
			{{ course.description }}
		</div>
		<div>
			<p>{{ course.tags | join(', ') }}</p>
		</div>
		</div>
  </div>
</div>

<div class="container mx-auto px-4 mt-4">
	<div class="card bg-base-100 shadow">
		<div class="card-body">
    <h3 class="text-xl font-bold">Class</h3>
		{% if classes %}
			<div class="overflow-x-auto">
			<table class="table">
				<tbody>
				{% for class_ in classes %}
					<tr>
						<td>
							<a href="{{ url_for('classes.view', class_id=class_.id) }}">{{ class_.name }}</a>
						</td>
						<td>
							{% if class_ not in enrolled_classes %}
								<a href="{{ url_for('classes.enroll', class_id=class_.id) }}">enroll</a>
              {% else %}
								enrolled
							{% endif %}
						</td>
					</tr>
				{% endfor %}
				</tbody>
			</table>
			</div>
		{% else %}
			No available class
		{% endif %}
		</div>
	</div>
</div>

<div class="container mx-auto px-4 mt-4">
  <div class="card bg-base-100 shadow">
		<div class="card-body">
    {% if course.assignments | count > 0 %}
      <h2 class="text-2xl font-bold">Assignments</h2>
	 <div class="overflow-x-auto">
	 <table class="table">
			<thead>
				<tr>
					<th>Name</th>
					<th>Description</th>
				</tr>
			</thead>
			<tbody>
{% for assignment in course.assignments %}
				<tr>
          <td>
            {# <a href="{{ url_for('assignments.view', assignment_id=assignment.id) }}"> #}
              {{ assignment.name }}
              {# </a> #}
					</td>
					<td>
						{{ assignment.description }}
					</td>
				</tr>
{% endfor %}
			</tbody>
		</table>
	 </div>
		{% endif %}

		</div>
  </div>
</div>
{% endblock %}
