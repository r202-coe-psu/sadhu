{% extends '/base/default-dashboard.html.j2' %}


{% block dashboard_title %}
Courses
{% endblock %}

{% block breadcrumbs %}
<li><a href="{{ url_for('courses.index') }}">Courses</a></li>
{% endblock %}

{% block content %}
<div class="container mx-auto px-4">
	{% if courses %}
	 <div class="overflow-x-auto">
	 <table class="table">
			<thead>
				<tr>
					<th>Name</th>
					<th>Description</th>
				</tr>
			</thead>
			<tbody>
{% for course in courses %}
				<tr>
					<td>
						<a href="{{ url_for('courses.view', course_id=course.id) }}">{{ course.name }}</a>
					</td>
		<td>
			{{ course.description }}
		</td>
				</tr>
{% endfor %}
			</tbody>
   </table>
	 </div>
 {% else %}
   <h3 class="text-xl font-semibold">
    There are no available course now.
   </h3>
		{% endif %}

</div>

{% endblock %}
