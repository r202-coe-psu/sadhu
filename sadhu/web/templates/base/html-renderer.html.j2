{% import '/base/error-handler.html.j2' as eh %}

{% macro render_field(field, class_='') -%}
{# Detect textareas by their widget so StringField/TagListField fields that use a
   TextArea() widget are styled (and sized) as textareas, not single-line inputs. #}
{%- set is_select = field.type in ['SelectField', 'SelectMultipleField'] -%}
{%- set is_textarea = not is_select and field.widget.input_type is not defined -%}
{%- set widget_class = 'select' if is_select else ('textarea' if is_textarea else 'input') -%}
{%- set style = '%s w-full %s %s' | format(widget_class, class_, eh.get_validate_class(field.errors)) -%}
<div class="form-control w-full mb-3">
{{ field.label(class_='label font-medium') }}
{%- if is_textarea -%}
{{ field(class_=style, rows=5, wrap='soft') }}
{%- else -%}
{{ field(class_=style) }}
{%- endif -%}
</div>
{{ eh.get_error_messages(field.errors) }}
{%- endmacro %}

{% macro render_checkbox(field) -%}
<div class="form-control mb-3">
  <label class="label cursor-pointer justify-start gap-3">
    {{ field(class_='checkbox') }}
    <span class="label-text">{{ field.label.text }}</span>
  </label>
</div>
{%- endmacro %}


{% macro render_fileinput(field) -%}
<div class="form-control w-full mb-3">
  {{ field.label(class_='label font-medium') }}
  <div class="join w-full">
    <input type="text" placeholder="{{ field.label.text }}" readonly class="input join-item w-full attach-file-{{field.name}}">
    {{ field(style="display: none;") }}
    <div class="btn join-item attach-file-{{field.name}}">
      <i class="fa-solid fa-paperclip"></i>
    </div>
  </div>
</div>
{%- endmacro %}


{% macro render_select(field) -%}
{{ render_field(field) }}
{%- endmacro %}


{% macro render_multiple_select(field) -%}
{{ render_field(field) }}
{%- endmacro %}

{% macro render_search_multiple_select(field) -%}
{{ render_field(field) }}
{%- endmacro %}

{% macro render_calendar(field, calendar_id='calendar', input_type='text', enable_time=False) -%}
<div class="form-control w-full mb-3" id="{{ calendar_id }}">
  {{ field.label(class_='label font-medium') }}
  {{ field(class_='input w-full %s' | format('js-datetimepicker' if enable_time else 'js-datepicker'), type=input_type, autocomplete='off') }}
</div>
{{ eh.get_error_messages(field.errors) }}
{%- endmacro %}
