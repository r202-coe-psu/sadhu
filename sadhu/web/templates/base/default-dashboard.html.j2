{% extends "/base/base-layout.html.j2" %}

{% block title %}{{ config.get('APP_TITLE') }} Dashboard{% endblock %}

{% block default_head %}{% endblock default_head %}


{% block body %}
<div class="drawer lg:drawer-open">
  <input id="dashboard-drawer" type="checkbox" class="drawer-toggle" />

  <div class="drawer-content flex flex-col min-h-screen">

    {# begin top bar (mobile only) #}
    <div class="navbar bg-neutral text-neutral-content lg:hidden sticky top-0 z-30">
      <label for="dashboard-drawer" class="btn btn-square btn-ghost drawer-button">
        <i class="fa-solid fa-bars"></i>
      </label>
      <div class="px-2 text-lg">
        {% block dashboard_title %}Dashboard{% endblock %}
      </div>
    </div>
    {# end top bar (mobile only) #}

    {# begin main article #}
    <header>
      <div class="bg-base-100 border-b border-base-300 px-6 py-4 hidden lg:block">
        <h1 class="text-3xl font-bold">
          {{ self.dashboard_title() }}
        </h1>
      </div>
    </header>

    <main class="p-5 grow min-h-[75vh]">
      {%- if self.dashboard_title().lower() != 'dashboard' %}
      <div class="card bg-base-100 shadow mb-4">
        <div class="card-body py-3">
          <div class="breadcrumbs text-lg">
            <ul>
            {% block breadcrumbs %}{% endblock %}
            </ul>
          </div>
        </div>
      </div>
      {% endif -%}
{% block content %}{% endblock %}
    </main>

    <footer class="bg-base-100 border-t border-base-300 py-8">
{% include "/base/footer.html.j2" %}
    </footer>
    {# end main article #}

  </div>

  {# begin sidebar #}
  <div class="drawer-side z-40">
    <label for="dashboard-drawer" aria-label="close sidebar" class="drawer-overlay"></label>
    <ul class="menu bg-neutral text-neutral-content min-h-full w-64 p-4">
      {% include "/base/toolbar-dashboard.html.j2" with context %}
    </ul>
  </div>
  {# end sidebar #}

</div>
{% endblock body %}
