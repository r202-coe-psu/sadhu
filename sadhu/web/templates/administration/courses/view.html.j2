{% extends '/administration/courses/index.html.j2' %}
{% import '/base/error-handler.html.j2' as eh %}

{% block dashboard_title %}Course: {{ course.name }}{% endblock %}

{% block breadcrumbs %}
{{ super() }}
<li>{{ course.name }}</li>
{% endblock %}

{% block content %}
  <div class="container mx-auto px-4">
    <div class="card bg-base-100 shadow">
      <div class="card-body">
        <div>
          {{ course.description }}
        </div>
        <div>
          for {{ course.languages | join(', ') }}
        </div>
        <div>
          <p>{{ course.tags | join(', ') }}</p>
        </div>
      </div>
    </div>
  </div>


<div class="container mx-auto px-4 mt-5">

  {% if course.get_assignments() | count > 0 %}
  <div class="overflow-x-auto">
  <table class="table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Description</th>
          <th>Operation</th>
        </tr>
      </thead>
      <tbody>
  {% for assignment in course.assignments %}
        <tr>
          <td>
            <a href="{{ url_for('administration.assignments.view', assignment_id=assignment.id) }}">{{ assignment.name }}</a>
          </td>
          <td>
            {{ assignment.description }}
          </td>
          <td>
            <a href="{{ url_for('administration.assignments.delete', assignment_id=assignment.id) }}" class="btn btn-circle btn-primary"><i class="fa-solid fa-trash"></i></a>

          </td>
        </tr>
  {% endfor %}
      </tbody>
    </table>
  </div>
    {% endif %}

</div>
{% endblock %}
