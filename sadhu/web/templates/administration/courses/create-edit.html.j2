{% extends '/administration/courses/index.html.j2' %}
{% import '/base/error-handler.html.j2' as eh %}
{% import '/base/html-renderer.html.j2' as renderer %}

{% block dashboard_title %}
  {% if 'edit' in request.path %}
    Edit Course: {{ form.name.data }}
  {% else %}
    Create Course
  {% endif %}
{% endblock %}

{% block breadcrumbs %}
  {{ super() }}
  {% if 'edit' in request.path %}
    <li>Edit Course: {{ form.name.data }}</li>
  {% else %}
    <li>Create Course</li>
  {% endif %}
{% endblock %}

{% block content %}
<div class="container mx-auto px-4">
  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <form method="POST">
        {{ form.csrf_token }}
        {{ renderer.render_field(form.name) }}
        {{ renderer.render_field(form.description) }}
        {{ renderer.render_select(form.languages) }}
        {{ renderer.render_field(form.tags) }}
        {{ renderer.render_search_multiple_select(form.contributors) }}
        {% if 'edit' in request.path %}
          <button name="create" type="submit" class="btn btn-primary">Edit</button>
        {% else %}
          <button name="create" type="submit" class="btn btn-primary">Create</button>
        {% endif %}
      </form>
    </div>
  </div>
</div>

{% endblock %}
