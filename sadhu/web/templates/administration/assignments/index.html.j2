{% extends '/base/default-dashboard.html.j2' %}

{% block breadcrumbs %}
<li><a href="{{ url_for('administration.assignments.index') }}">Assignments</a></li>
{% endblock %}

{% block dashboard_title %}
  Assignments
{% endblock %}

{% block content %}
<div class="pt-2">
  <a href="{{ url_for('administration.assignments.create_or_edit') }}" class="btn btn-primary"><i class="fa-solid fa-plus"></i>Add</a>
</div>

<div class="pt-2">
  <div class="pt-2">
    {% if assignments %}
      <h2 class="text-2xl font-bold mt-4 mb-2">Own assignments</h2>
      {{ render_table(assignments) }}
    {% endif %}
    {% if other_assignments %}
      <h2 class="text-2xl font-bold mt-4 mb-2">Other assignments</h2>
      {{ render_table(other_assignments) }}
    {% endif %}
  </div>
</div>
{% endblock %}

{% macro render_table(assignments) %}
<div class="mt-5">
	{% if assignments %}
	 <div class="overflow-x-auto">
	 <table class="table">
			<thead>
				<tr>
					<th>Name</th>
					<th>Description</th>
          <th>Level</th>
					<th>Course</th>
					<th>Score</th>
					<th>Operation</th>
				</tr>
			</thead>
			<tbody>
{% for assignment in assignments %}
				<tr>
					<td>
						<a href="{{ url_for('administration.assignments.view', assignment_id=assignment.id) }}">{{ assignment.name }}</a>
					</td>
					<td>
						{{ assignment.description }}
          </td>
          <td>
            {{ assignment.level}}
          </td>
          <td>
            <a href="{{ url_for("administration.courses.view", course_id=assignment.course.id) }}">
              {{ assignment.course.name }}
            </a>
          </td>
					<td>
						{{ assignment.score }}
          </td>
          <td class="whitespace-nowrap">
            <a class="btn btn-circle btn-primary" href="{{ url_for('administration.assignments.view', assignment_id=assignment.id) }}">
              <i class="fa-solid fa-eye"></i>
            </a>
            <a class="btn btn-circle btn-primary" href="{{ url_for("administration.assignments.create_or_edit", assignment_id=assignment.id) }}">
              <i class="fa-solid fa-pen-to-square"></i>
            </a>
			      <a class="btn btn-circle btn-primary" href="{{ url_for('administration.assignments.delete', assignment_id=assignment.id) }}">
              <i class="fa-solid fa-trash"></i>
            </a>
          </td>
				</tr>
{% endfor %}
			</tbody>
		</table>
		</div>
		{% endif %}
</div>
{% endmacro %}
