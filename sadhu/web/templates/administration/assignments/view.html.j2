{% extends '/administration/assignments/index.html.j2' %}
{% import '/base/html-renderer.html.j2' as renderer %}

{% block dashboard_title %}
  Assignment: {{ assignment.name }}
{% endblock %}

{% block breadcrumbs %}
  {{ super() }}
  <li>{{ assignment.name }}</li>
{% endblock %}

{% block content %}
<div class="container mx-auto px-4">
  <div class="card bg-base-100 shadow">
    <div class="card-body">
		<h2 class="card-title text-2xl">{{ assignment.name }}</h2>
		<div>
			<p>course <a href="{{ url_for('administration.courses.view', course_id=assignment.course.id) }}">{{ assignment.course.name }}</a></p>
		</div>
		<div>
			{{ assignment.description }}
		</div>
		<div>
			Level: {{assignment.level}}
		</div>
		<div>
			Score: {{ assignment.score }}
		</div>
		<div>
			<p>{{ assignment.tags | join(', ') }}</p>
		</div>
		<div>
			Choice: {{assignment.random_or_not}}
		</div>
		<div>
			Number of Random: {{assignment.random_count}}
		</div>

    <form method="POST" action="{{ url_for('administration.assignments.add_challenge', assignment_id=assignment.id) }}">
        {{ form.csrf_token }}
        {{ renderer.render_multiple_select(form.challenges) }}
        <button type="submit" class="btn btn-primary">add</button>
    </form>
    </div>
  </div>
</div>

<div class="container mx-auto px-4 mt-4">
	{% if assignment.challenges | count > 0 %}
	 <div class="overflow-x-auto">
	 <table class="table">
			<thead>
				<tr>
					<th>Name</th>
					<th>Description</th>
					<th>level</th>
          <th>Score</th>
          <th>Action</th>
				</tr>
			</thead>
			<tbody>
{% for challenge in assignment.challenges %}
				<tr>
					<td>
						<a href="{{ url_for('administration.challenges.view', challenge_id=challenge.id) }}">{{ challenge.name }}</a>
					</td>
					<td>
						{{ challenge.description }}
					</td>
					<td>
						{{ challenge.level}}
					</td>
					<td>
						{{ challenge.score }}
          </td>
          <td>
            <a href="{{ url_for('administration.assignments.delete_challenge', assignment_id=assignment.id, challenge_id=challenge.id) }}" class="btn btn-circle btn-error">
              <i class="fa-solid fa-trash"></i>
            </a>
          </td>
				</tr>
{% endfor %}
			</tbody>
		</table>
		</div>
		{% endif %}
</div>


{% endblock %}
