{% extends '/base/default-dashboard.html.j2' %}

{% block breadcrumbs %}
<li><a href="{{ url_for('administration.classes.index') }}">Classes</a></li>
{% endblock %}

{% block dashboard_title %}
Classes
{% endblock %}

{% block content %}
    <div class="flex flex-wrap gap-2 mb-4">
      <a href="{{ url_for('administration.classes.create') }}" class="btn"><i class="fa-solid fa-plus"></i>Add</a>
      <a href="{{ url_for('administration.courses.index') }}" class="btn"><i class="fa-solid fa-book"></i>Courses</a>
    </div>


    {% if owner_classes %}
    <div class="mt-2">
      <h2 class="text-2xl font-bold mb-2">Owner</h2>
      <div class="overflow-x-auto">
      <table class="table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Description</th>
            <th>Operation</th>
          </tr>
        </thead>
        <tbody>
      {% for class_ in owner_classes %}
          <tr>
            <td>
              <a href="{{ url_for('administration.classes.view', class_id=class_.id) }}">{{ class_.name }}</a>
            </td>
            <td>
              {{ class_.description }}
            </td>
            <td class="whitespace-nowrap">
              <a class="btn btn-circle btn-primary" href="{{ url_for('administration.classes.edit', class_id=class_.id) }}"><i class="fa-solid fa-pen-to-square"></i></a>
              <a class="btn btn-circle btn-primary" href="{{ url_for('administration.classes.list_students', class_id=class_.id) }}"><i class="fa-solid fa-users"></i></a>
              <a class="btn btn-circle btn-primary" href="{{ url_for('administration.classes.delete', class_id=class_.id) }}"><i class="fa-solid fa-trash"></i></a>
            </td>
          </tr>
      {% endfor %}
        </tbody>
      </table>
      </div>
    </div>
  {% endif %}

{% if classes %}
  <div class="mt-2">
    <h2 class="text-2xl font-bold mb-2">Other Classes</h2>
    <div class="overflow-x-auto">
    <table class="table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Description</th>
          <th>Operation</th>
        </tr>
      </thead>
      <tbody>
    {% for class_ in classes %}
        <tr>
          <td>
            <a href="{{ url_for('administration.classes.view', class_id=class_.id) }}">{{ class_.name }}</a>
          </td>
          <td>
            {{ class_.description }}
          </td>
          <td class="whitespace-nowrap">
            <a class="btn btn-circle btn-primary" href="{{ url_for('administration.classes.edit', class_id=class_.id) }}"><i class="fa-solid fa-pen-to-square"></i></a>
            <a class="btn btn-circle btn-primary" href="{{ url_for('administration.classes.list_students', class_id=class_.id) }}"><i class="fa-solid fa-users"></i></a>
            <a class="btn btn-circle btn-primary" href="{{ url_for('administration.classes.delete', class_id=class_.id) }}"><i class="fa-solid fa-trash"></i></a>
          </td>
        </tr>
    {% endfor %}
      </tbody>
    </table>
    </div>
  </div>
{% endif %}


{% endblock %}
