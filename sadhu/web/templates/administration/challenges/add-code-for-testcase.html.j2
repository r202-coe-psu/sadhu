{% extends '/administration/challenges/index.html.j2' %}
{% import '/base/html-renderer.html.j2' as renderer %}

{% block additional_js %}
  {{ super() }}

  <script type="text/javascript">
    $(".attach-file-code").click(function() {
      $(this).parent().find("#code").click();
    });

    $('#code')
      .on('change', function(e) {
        var name = e.target.files[0].name;
        $('.attach-file-code', $(e.target).parent()).val(name);
      });

  </script>

{% endblock %}

{% block dashboard_title %}
  Code for Test Case: {{ challenge.name }}
{% endblock %}

{% block breadcrumbs %}
  {{ super() }}
  <li>Code for Test Case: {{ challenge.name }}</li>
{% endblock %}


{% block content %}
  <div class="container mx-auto px-4">
    <div class="card bg-base-100 shadow">
      <div class="card-body">
      <form method="POST" enctype="multipart/form-data">
        {{ form.csrf_token }}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {{ renderer.render_fileinput(form.code) }}
          {{ renderer.render_select(form.language) }}
        </div>
        <button name="create" type="submit" class="btn btn-primary">Submit</button>
      </form>
      </div>
    </div>
  </div>

{% endblock %}
