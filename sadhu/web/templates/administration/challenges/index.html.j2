{% extends '/base/default-dashboard.html.j2' %}

{% block breadcrumbs %}
<li><a href="{{ url_for('administration.challenges.index') }}">Challenges</a></li>
{% endblock %}

{% block dashboard_title %}
  Challenges
{% endblock %}

{% block content %}
<div class="pt-2">
  <a href="{{ url_for('administration.challenges.create') }}" class="btn btn-primary"><i class="fa-solid fa-plus"></i>Add</a>
</div>

<div class="pt-2">
  <div class="pt-2">
    {% if challenges %}
      <h2 class="text-2xl font-bold mt-4 mb-2">Own Challenges</h2>
      {{ render_table(challenges) }}
    {% endif %}
    {% if other_challenges %}
      <h2 class="text-2xl font-bold mt-4 mb-2">Other Challenges</h2>
      {{ render_table(other_challenges) }}
    {% endif %}
  </div>
</div>
{% endblock %}

{% macro render_table(challenges) %}
  <div class="overflow-x-auto">
  <table class="table">
    <thead>
      <tr>
          <th>Name</th>
          <th>Level</th>
          <th>Score</th>
          <th>Tags</th>
          <th>Operation</th>
      </tr>
    </thead>

    <tbody>
    {% for challenge in challenges %}
          <tr>
            <td>
              <a href="{{ url_for('administration.challenges.view', challenge_id=challenge.id) }}">{{ challenge.name }}</a>
            </td>
            <td>
              {{challenge.level}}
            </td>
            <td>
                {{challenge.score}}
            </td>
            <td>
                {{ challenge.tags | join(', ') }}
            </td>
            <td class="whitespace-nowrap">
              <a href="{{ url_for('administration.challenges.view', challenge_id=challenge.id) }}" class="btn btn-circle btn-primary"><i class="fa-solid fa-eye"></i></a>
              <a href="{{ url_for('administration.challenges.edit', challenge_id=challenge.id) }}" class="btn btn-circle btn-primary"><i class="fa-solid fa-pen-to-square"></i></a>
            </td>
          </tr>
    {% endfor %}
    </tbody>
  </table>
  </div>
  {% endmacro %}
