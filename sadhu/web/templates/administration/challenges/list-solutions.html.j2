{% extends '/administration/challenges/index.html.j2' %}
{% import '/base/solution-style.html.j2' as solution_style %}

{% block breadcrumbs %}
  {{ super() }}
  <li><a href="{{ url_for('administration.challenges.view', challenge_id=challenge.id, **request.args) }}">{{ challenge.name }}</a></li>
  <li>Solutions</li>
{% endblock %}

{% block dashboard_title %}
Solution: {{ challenge.name }}
{% endblock %}

{% block content %}
<div class="container mx-auto px-4">
  <div class="card bg-base-100 shadow">
    <div class="card-body">
    <h2 class="card-title text-2xl">{{ challenge.name }}</h2>
		<h3 class="text-lg font-semibold mt-4">Description</h3>
		<div>
      {{ challenge.description }}
    </div>
    </div>
  </div>
</div>

<div class="container mx-auto px-4 mt-5">
  {% if solutions | count > 0 %}
    <div class="overflow-x-auto">
    <table class="table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Class Name</th>
        <th>Submitted Date</th>
        <th>Check Status</th>
        <th>Pass Test</th>
        <th>Test Case Score</th>
        <th>Score</th>
        <th>Operation</th>
      </tr>
    </thead>
    <tbody>
{% for solution in solutions %}
  <tr class="{{ solution_style.get_solution_class(solution) }}">
    <td>
      <a href="{{ url_for('administration.classes.show_user_score', class_id=solution.enrolled_class.id, user_id=solution.owner.id) }}">{{ solution.owner.first_name }}</a>
      </td>
        <td>
          <a href="{{ url_for('administration.classes.view', class_id=solution.enrolled_class.id) }}">{{ solution.enrolled_class.name }}</a>
        </td>
        <td>
          {{ solution.submitted_date | ymd }}
        </td>
        <td>
          {{ solution.status }}
        </td>
        <td>
          {{ solution.passed }}
        </td>
        <td class="text-right">
          {{ solution.count_pass_testcases() }} /
          {{ solution.test_results | count }}
        </td>
        <td class="text-right">
          {{ '{:.2f}'.format(solution.score) }}
        </td>
        <td>
            {% if solution.status == 'complete' %}
              <a href="{{ url_for('administration.solutions.view', solution_id=solution.id, class_id=request.args.get('class_id')) }}" class="btn btn-circle btn-primary"><i class="fa-solid fa-eye"></i></a>
            {% else %}
              <i class="fa-solid fa-eye"></i>
            {% endif %}
        </td>
      </tr>
{% endfor %}
    </tbody>
  </table>
  </div>
  {% endif %}
</div>

{% endblock %}
