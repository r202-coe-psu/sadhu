{% extends '/base/default-dashboard.html.j2' %}

{% block breadcrumbs %}
<li><a href="{{ url_for('administration.users.index') }}">Users</a></li>
{% endblock %}

{% block content %}
<div class="container mx-auto px-4">

 <div class="overflow-x-auto">
 <table class="table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Classes</th>
      </tr>
    </thead>
    <tbody>
{% for user in users  %}
      <tr>
        <td>
          {{ user.first_name }} {{ user.last_name }}
          ({{ user.metadata.get('thai_first_name', '') }} {{ user.metadata.get('thai_last_name', '') }})
          {#
          <a href="{{ url_for('administration.courses.view', course_id=course.id) }}">{{ course.name }}</a>
          #}
        </td>
        <td>
          {% for e in user.get_enrollments() %}
            {{ e.enrolled_class.name }}
          {% endfor %}
        </td>
      </tr>
{% endfor %}
    </tbody>
  </table>
 </div>

</div>

{% endblock %}
