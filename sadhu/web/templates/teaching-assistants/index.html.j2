{% extends '/base/default-dashboard.html.j2' %}

{% block content %}
<div class="container mx-auto px-4">
    <h4 class="text-xl font-bold">Teaching Assistant Mode</h4>
</div>

<div class="container mx-auto px-4 pt-5">
  <h5 class="text-lg font-semibold mb-2">Class</h5>
  <div class="overflow-x-auto">
  <table class="table">
    <thead>
      <tr>
          <th>Name</th>
          <th>Operations</th>
      </tr>
    </thead>

    <tbody>
      {% for class_ in classes %}
      <tr>
        <td>
          <a href="{{ url_for('teaching_assistants.classes.view', class_id=class_.id) }}">{{ class_.name }}</a>
        </td>
        <td>
          <a href="{{ url_for('teaching_assistants.classes.view', class_id=class_.id) }}" class="btn btn-circle btn-primary"><i class="fa-solid fa-eye"></i></a>
        </td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  </div>

</div>

{% endblock %}
