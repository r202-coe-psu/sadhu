{% extends '/administration/assignments/index.html.j2' %}
{% import '/base/error-handler.html.j2' as eh %}
{% import '/base/html-renderer.html.j2' as renderer %}

{% block additional_js %}
{% endblock %}
{% block content %}
<div class="container mx-auto px-4">
  <div class="card bg-base-100 shadow">
    <div class="card-body">
    <h3 class="text-2xl font-bold mb-4">Create Assignments</h3>
    <form method="POST" action="{{ request.url }}">
      {{ form.csrf_token }}
      {{ renderer.render_field(form.name) }}
      {{ renderer.render_field(form.description) }}
      {{ renderer.render_field(form.score) }}
      {{ renderer.render_field(form.course) }}
      {{ renderer.render_field(form.tags) }}
      <div class="mt-4">
        <button name="create" type="submit" class="btn btn-primary">Create</button>
      </div>
    </form>
    </div>
  </div>
</div>

{% endblock %}
