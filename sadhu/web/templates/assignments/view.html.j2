{% extends '/assignments/index.html.j2' %}

{% block dashboard_title %}Assignment: {{ assignment.name }}{% endblock %}

{% block breadcrumbs %}
{{ super() }}
<li>{{ assignment.name }}</li>
{% endblock %}


{% block content %}
<div class="container mx-auto px-4">
	<div class="card bg-base-100 shadow">
		<div class="card-body">
		<div>
			<p>Course <a href="{{ url_for('courses.view', course_id=assignment.course.id) }}">{{ assignment.course.name }}</a></p>
      {#
      <p>Class <a href="{{ url_for('classes.view', class_id=class_.id) }}">{{ class_.name }}</a></p>
      #}
		</div>
		<div>
			{{ assignment.description }}
		</div>
		<div>
			Score: {{ assignment.score }}
		</div>
		<div>
			<p>{{ assignment.tags | join(', ') }}</p>
		</div>
		</div>
  </div>
</div>

<div class="container mx-auto px-4 mt-5">

	{% if assignment.challenges | count > 0 %}
		<div class="overflow-x-auto">
    <table class="table">
			<thead>
				<tr>
					<th>Name</th>
					<th>Description</th>
					<th>Score</th>
          {# <th>Submitted</th> #}
				</tr>
			</thead>
			<tbody>
{% for challenge in assignment.challenges %}
				<tr>
					<td>
            <a href="{{ url_for('challenges.view', challenge_id=challenge.id, **request.args) }}">{{ challenge.name }}</a>
					</td>
					<td>
						{{ challenge.description }}
					</td>
					<td>
						{{ challenge.score }}
					</td>
          {#
          <td>
            {{'Submitted' if challenge.get_solutions(class_.id) else 'Waiting' }}
					</td>
          #}
				</tr>
{% endfor %}
			</tbody>
		</table>
		</div>
		{% endif %}

</div>


{% endblock %}
