{% extends '/scoreboards/index.html.j2' %}

{% block additional_js %}
  <script src="//cdnjs.cloudflare.com/ajax/libs/fabric.js/5.2.4/fabric.js"></script>

  {#

  <script type="text/javascript" src="{{ url_for('static', filename='brython_modules/brython.js') }}"></script>
  <script type="text/javascript" src="{{ url_for('static', filename='brython_modules/brython_stdlib.js') }}"></script>

  #}


<script src="https://cdn.jsdelivr.net/npm/brython@3/brython.min.js">
</script>
<script src="https://cdn.jsdelivr.net/npm/brython@3/brython_stdlib.js">
</script>

  <script type="text/javascript" src="{{ url_for('static', filename='brython_modules/scoreboards.brython.js') }}"></script>
  <script type="text/javascript">
    brython(1);
  </script>
{% endblock %}

{% block dashboard_title %}Scoreboard: {{ class_.name }}{% endblock %}

{% block breadcrumbs %}
{{ super() }}
<li>{{ class_.name }}</li>
{% endblock %}


{% block content %}
  <div>
    <canvas id="scoreboard" style="width: 100%!important; height: 80vh;"></canvas>
  </div>
  <script type="text/python">
    from scoreboards import display
    from browser import document

    canvas = document['scoreboard']
    score_board = display.ScoreBoard(
        'scoreboard',
        width=canvas.clientWidth,
        height=canvas.clientHeight,
        data_url="{{ url_for('scoreboards.list_assignment_scores', class_id=class_.id, assignment_id=assignment.id) }}"
        )
    score_board.run()
  </script>
{% endblock %}

