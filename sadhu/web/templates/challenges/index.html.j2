{% extends '/base/default-dashboard.html.j2' %}

{% block dashboard_title %}Challenges{% endblock %}

{% block breadcrumbs %}
<li><a href="{{ url_for('challenges.index', **request.args.to_dict()) }}">Challenges</a></li>
{% endblock %}

{% block content %}

<div class="container mx-auto px-4">
      <div class="overflow-x-auto">
      <table class="table">
        <thead>
          <tr>
              <th>Name</th>
              <th>Score</th>
              <th>Tags</th>
              <th>Your Scores</th>
          </tr>
        </thead>
        <tbody>
  {% for challenge in challenges %}
          <tr>
            <td>
              <a href="{{ url_for('challenges.view', challenge_id=challenge.id, **request.args.to_dict()) }}">{{ challenge.name }}</a>
            </td>
            <td>
                {{challenge.score}}
            </td>
            <td>
                {{ challenge.tags | join(', ') }}
            </td>
            <td class="text-right">
              {{ '{:.02f}'.format(challenge.get_solution_score(class_, current_user)) }}
            </td>
          </tr>
  {% endfor %}
        </tbody>
      </table>
      </div>
</div>

{% endblock %}
