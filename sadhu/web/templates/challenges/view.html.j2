{% block dashboard_title %}
Challenge: {{ challenge.name }}
{% endblock %}

{% block breadcrumbs %}
  {{ super() }}
  <li><a href="{{ url_for('challenges.view', challenge_id=challenge.id, **request.args.to_dict()) }}">{{ challenge.name }}</a></li>
{% endblock %}

{% block content %}
<div class="container mx-auto px-4">
  <div class="alert alert-info">
    <h2 class="text-xl font-bold">
      Assignment: <a href="{{ url_for('assignments.practice', assignment_id=assignment.id,  **request.args.to_dict()) }}">{{ assignment.name }}</a>
    </h2>
  </div>
</div>

<div class="container mx-auto px-4 mt-4">
  <div class="card bg-base-100 shadow">
		<div class="card-body text-lg leading-normal">
		<h3 class="text-2xl font-bold">{{ challenge.name }}</h3>
		{#
		<h4>Description</h4>
		<div>
			{{ challenge.description }}
		</div>
		#}
		<h4 class="text-lg font-semibold mt-4">Problem Statement</h4>
		<div>
			{{ markdown(challenge.problem_statement, extensions=['fenced_code', 'codehilite', 'mdx_math', 'tables']) | safe }}
		</div>

		<h4 class="text-lg font-semibold mt-4">Input Format</h4>
		<div>
			{{ challenge.input_format if challenge.input_format and challenge.input_format | count > 0 else '-' }}
		</div>

		<h4 class="text-lg font-semibold mt-4">Constrains</h4>
		<div>
			{{ challenge.constrains if challenge.constrains and challenge.constrains | count > 0 else '-'}}
		</div>

		<h4 class="text-lg font-semibold mt-4">Output Format</h4>
		<div>
			{{ markdown(challenge.output_format, extensions=['fenced_code', 'codehilite', 'mdx_math', 'tables']) | safe }}
		</div>

		<h4 class="text-lg font-semibold mt-4">Score</h4>
		<div>
      <span class="text-error"><b>{{ challenge.score }}</b></span>
		</div>

		<h4 class="text-lg font-semibold mt-4">Tags</h4>
		<div>
      {{ challenge.tags | join(', ') }}
    </div>

    {%- if challenge.test_cases | count > 0 %}
		<h4 class="text-lg font-semibold mt-4">Public Test Case</h4>
    <div class="overflow-x-auto">
    <table class="table">
      <thead>
        <tr>
            <th>Input</th>
            <th>System Output</th>
        </tr>
      </thead>

      <tbody>
        {%- for t in challenge.test_cases if t.public %}
        <tr>
          <td><pre>{{ t.input_string }}</pre></td>
          <td>
            <pre>{{ t.output_string }}</pre>
          </td>
        </tr>
        {% endfor -%}
      </tbody>
    </table>
    </div>
    {% endif -%}
		</div>
  </div>
</div>

{% if request.args.get('class_id', None) %}
{% if show_submission %}
<div class="container mx-auto px-4 mt-4">
	<div class="card bg-base-100 shadow">
		<div class="card-body">
		<form action="{{ url_for('challenges.submit_solution', challenge_id=challenge.id, class_id=request.args.get('class_id')) }}" enctype="multipart/form-data" method="POST">
			{{ form.csrf_token }}
			{{ renderer.render_fileinput(form.code) }}
			<button name="submit" type="submit" class="btn btn-primary">Submit</button>
		</form>
		</div>
  </div>
</div>
{% endif %}

<div class="container mx-auto px-4 mt-4">
  {% if solutions %}
<script type="text/python">
  from browser import document, html, ajax, timer
  import json

  sol_status = {}
  _timer = None

  url = "{{ url_for('solutions.status_api', solution_id='solution_id') }}"

  def set_get_status_timeout():
    global _timer
    if _timer:
      timer.clear_timeout(_timer)

    _timer = timer.set_timeout(get_status_from_server, 5000)

  def on_complete(req):
    global sol_status

    obj = json.loads(req.text)
    print('got status', obj)

    old_status = sol_status[obj['id']]
    if old_status == obj['status']:
      set_get_status_timeout()
      return

    tr = document['solution-'+obj['id']]
    for td in tr.children:
      if td.headers == 'status':
        td.text = obj['status']
      elif td.headers == 'passed':
        td.text = obj['passed']
      elif td.headers == 'score':
        td.text = obj['score']

    if obj['status'] == 'complete':
      if obj['passed'] == True:
        tr.className = 'bg-success/20'
      else:
        tr.className = 'bg-error/20'

      a = document[f'solution-{obj["id"]}-view']
      a.className = a.className.replace('btn-disabled', '').strip()

      sol_status.pop(obj['id'])
    else:
      set_get_status_timeout()



  def check_solution_status():
    sol_status = {}
    trs = document['solution-status'].children
    for tr in trs:
      for td in tr.children:
        if td.headers == 'status' and td.text.strip() != 'complete':
          solution_id = tr.id.split('-')[-1]
          sol_status[solution_id] = td.text.strip()
          break
    return sol_status

  def get_status_from_server():
    global sol_status
    for sol_id in sol_status:
      request_url = url.replace('solution_id', sol_id)
      ajax.get(request_url, oncomplete=on_complete)

  sol_status = check_solution_status()
  if len(sol_status) > 0:
    get_status_from_server()

</script>
		  <div class="overflow-x-auto">
		  <table class="table">
        <thead>
          <tr>
            <th>Filename</th>
            <th>Submited Date</th>
            <th>Status</th>
            <th>Pass</th>
            <th>Score</th>
            <th>Operations</th>
          </tr>
        </thead>

        <tbody id="solution-status">
          {% for solution in solutions %}
          <tr id="solution-{{ solution.id }}" class="{{ solution_style.get_solution_class(solution) }}">
            <td headers="filename">{{ solution.code.filename }}</td>
            <td headers="submitted_date">{{ solution.submitted_date | ymd }}</td>
            <td headers="status">{{ solution.status }}</td>
            <td headers="passed">{{ solution.passed }}</td>
            <td headers="score">{{ '{:.2f}'.format(solution.score) }}</td>
            <td headers="operation">
              {% if solution.status == 'complete' %}
                <a id="solution-{{ solution.id }}-view" class="btn btn-circle btn-primary" target="blank" href="{{ url_for('solutions.view', solution_id=solution.id, class_id=request.args.get('class_id')) }}"><i class="fa-solid fa-eye"></i></a>
              {% else %}
                <a id="solution-{{ solution.id }}-view" class="btn btn-circle btn-primary btn-disabled" target="blank" href="{{ url_for('solutions.view', solution_id=solution.id, class_id=request.args.get('class_id')) }}"><i class="fa-solid fa-eye"></i></a>
              {% endif %}
            </td>
					</tr>
          {% endfor %}
        </tbody>
		  </table>
		  </div>
	  {% endif %}
</div>
{% endif %}

{% endblock %}
